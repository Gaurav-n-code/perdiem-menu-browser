# Square Sandbox credentials
# Get these from: https://developer.squareup.com/apps
# Create a sandbox application → Credentials tab

# Your sandbox access token (starts with EAAAl... or sandbox-...)
SQUARE_ACCESS_TOKEN=your_sandbox_access_token_here

# Square environment: "sandbox" or "production"
# Always use "sandbox" for local development
SQUARE_ENVIRONMENT=sandbox


# -------------------------------------------------------
# App config
# -------------------------------------------------------

# Base URL used for absolute URLs in metadata / og tags
NEXT_PUBLIC_APP_URL=http://localhost:3000
